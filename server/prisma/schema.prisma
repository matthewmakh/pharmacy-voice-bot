generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  cases        Case[]

  // Stripe Connect (claimant payout account)
  stripeAccountId         String?
  stripeAccountChargesEnabled Boolean @default(false)
  stripeAccountPayoutsEnabled Boolean @default(false)

  // Partner attorneys this user has used for handoffs
  attorneyPartners AttorneyPartner[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AttorneyPartner {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  firmName  String?
  email     String
  phone     String?
  barNumber String?
  state     String  @default("NY")
  notes     String? @db.Text

  // Default referral fee percentage (e.g. 20.00 for 20%)
  referralFeePercent Decimal @default(20) @db.Decimal(5, 2)

  cases Case[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Case {
  id     String     @id @default(cuid())
  status CaseStatus @default(DRAFT)
  strategy Strategy?
  title  String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Claimant
  claimantName     String?
  claimantBusiness String?
  claimantAddress  String?
  claimantEmail    String?
  claimantPhone    String?

  // Debtor
  debtorName       String?
  debtorBusiness   String?
  debtorAddress    String?
  debtorEmail      String?
  debtorPhone      String?
  debtorEntityType String?

  // Claim details
  amountOwed         Decimal?  @db.Decimal(12, 2)
  amountPaid         Decimal?  @db.Decimal(12, 2)
  serviceDescription String?   @db.Text
  agreementDate      DateTime?
  serviceStartDate   DateTime?
  serviceEndDate     DateTime?
  invoiceDate        DateTime?
  paymentDueDate     DateTime?
  hasWrittenContract Boolean   @default(false)
  invoiceNumber      String?

  // AI-synthesized data
  extractedFacts  Json?
  caseTimeline    Json?
  evidenceSummary Json?
  missingInfo     Json?
  caseStrength    String?
  caseAssessment  Json?

  // Generated outputs
  caseSummary      String? @db.Text
  demandLetter     String? @db.Text
  demandLetterHtml String? @db.Text
  finalNotice      String? @db.Text
  finalNoticeHtml  String? @db.Text
  filingPacket         String? @db.Text
  filingPacketHtml     String? @db.Text
  courtFormType         String?
  courtFormInstructions Json?
  courtFormVerification       Json?
  demandLetterVerification    Json?
  caseAnalysisVerification    Json?
  defaultJudgmentVerification Json?
  settlementVerification      Json?
  paymentPlanVerification     Json?
  defaultJudgment             String? @db.Text
  defaultJudgmentHtml   String? @db.Text

  industry String?
  notes String? @db.Text

  // Debtor research lookup results (persisted so they survive refresh)
  acrisResult    Json?
  courtHistory   Json?
  entityResult   Json?
  uccResult      Json?
  ecbResult      Json?
  pacerResult    Json?

  // Additional pre-trial documents
  affidavitOfServiceHtml String? @db.Text
  settlementHtml         String? @db.Text
  paymentPlanHtml        String? @db.Text

  // Phase A — Lob certified mail tracking
  demandLetterMailedAt    DateTime?
  demandLetterMailId      String?   // Lob letter ID
  demandLetterTracking    String?   // USPS tracking number
  demandLetterDeliveredAt DateTime?
  finalNoticeMailedAt     DateTime?
  finalNoticeMailId       String?
  finalNoticeTracking     String?
  finalNoticeDeliveredAt  DateTime?

  // Phase A — Resend tracked email
  demandLetterEmailedAt   DateTime?
  demandLetterEmailId     String?
  demandLetterEmailOpenedAt DateTime?
  finalNoticeEmailedAt    DateTime?
  finalNoticeEmailId      String?

  // Phase A — Dropbox Sign e-signature
  settlementSignatureRequestId String?
  settlementSignedAt           DateTime?
  settlementSignedPdfUrl       String?
  paymentPlanSignatureRequestId String?
  paymentPlanSignedAt           DateTime?
  paymentPlanSignedPdfUrl       String?

  // Phase A — Stripe Connect escrow
  stripePaymentIntentId   String?
  stripeChargeId          String?
  amountCollectedCents    Int?      // total collected via portal (cents)
  reclaimFeeCents         Int?      // 12% recovery fee taken
  payoutToClaimantCents   Int?
  payoutTransferId        String?
  payoutCompletedAt       DateTime?

  // Phase A — Defendant response portal
  portalToken             String?   @unique
  portalTokenExpiresAt    DateTime?
  portalLastViewedAt      DateTime?
  defendantDisputeText    String?   @db.Text
  defendantProposedPlan   Json?

  // Phase A — Auto follow-up cadence
  followUpEnabled         Boolean   @default(false)
  followUpStartedAt       DateTime?
  followUpNextRunAt       DateTime?
  followUpStepIndex       Int       @default(0)

  // Phase B — Filing tracking (any of: demand-letter civil filing, default judgment)
  defaultJudgmentFiledAt    DateTime?
  defaultJudgmentFilingMethod String? // "diy" | "infotrack" | "attorney" | "manual"
  defaultJudgmentIndexNumber String?  // court-issued index number

  // Phase B — DIY filing walkthrough state
  walkthroughType         String?  // "nyscef" | "edds" | "commercial-claims"
  walkthroughPurpose      String?  // "complaint" | "default-judgment"
  walkthroughStep         Int      @default(0)
  walkthroughStartedAt    DateTime?
  walkthroughCompletedAt  DateTime?
  walkthroughNotes        Json?    // per-step notes the user entered

  // Phase B — SCRA non-military affidavit (required for default judgment vs individual)
  scraAffidavitHtml       String?   @db.Text
  scraVerifiedAt          DateTime? // when user confirmed non-military status via DOD portal
  scraCertificateNumber   String?   // optional: certificate # from DOD portal

  // Phase B — Post-judgment doc generators (used as inputs to attorney handoff package)
  informationSubpoenaHtml  String? @db.Text
  restrainingNoticeHtml    String? @db.Text
  propertyExecutionHtml    String? @db.Text
  incomeExecutionHtml      String? @db.Text
  marshalRequestHtml       String? @db.Text

  // Phase B — Proof.com (notary + process serve)
  notarizationId           String?   // Proof Notarize transaction ID
  notarizationStatus       String?   // "pending" | "in-session" | "completed" | "failed"
  notarizedPdfUrl          String?   // signed/notarized PDF after RON
  notarizedAt              DateTime?
  processServeJobId        String?   // Proof Serve job ID
  processServeStatus       String?   // "pending" | "attempted" | "served" | "unsuccessful"
  processServeAffidavitUrl String?   // notarized affidavit of service PDF
  processServedAt          DateTime?

  // Phase B — InfoTrack NYSCEF/EDDS e-filing (paid path, $200 markup)
  infoTrackOrderId         String?
  infoTrackStatus          String?   // "submitted" | "accepted" | "rejected" | "filed"
  infoTrackPurpose         String?   // "complaint" | "default-judgment"
  infoTrackPlatform        String?   // "nyscef" | "edds"
  infoTrackFilingFeeCents  Int?      // court fee passthrough
  infoTrackServiceFeeCents Int?      // Reclaim's $200 markup
  infoTrackAcceptedAt      DateTime?
  infoTrackIndexNumber     String?
  infoTrackRejectionReason String?

  // Phase B — Attorney handoff
  attorneyPartnerId        String?
  attorneyPartner          AttorneyPartner? @relation(fields: [attorneyPartnerId], references: [id])
  attorneyHandoffStatus    String?   // "pending" | "accepted" | "declined" | "in-progress" | "resolved" | "lost"
  attorneyHandoffInitiatedAt DateTime?
  attorneyHandoffAcceptedAt DateTime?
  attorneyHandoffResolvedAt DateTime?
  attorneyHandoffToken     String?   @unique // magic-link token for partner attorney portal
  attorneyHandoffTokenExpiresAt DateTime?
  attorneyHandoffNotes     String?   @db.Text  // notes from claimant to attorney
  attorneyHandoffOutcome   String?   // partner attorney's report
  attorneyHandoffSettlementCents Int?
  referralFeeCents         Int?      // 20% of attorney contingency at resolution

  documents Document[]
  actions   CaseAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Document {
  id       String @id @default(cuid())
  caseId   String
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String

  classification String?
  extractedText  String? @db.Text
  extractedFacts Json?
  supportsTags   String[]
  confidence     Float?
  summary        String? @db.Text

  uploadedAt DateTime @default(now())

  @@index([caseId])
}

model CaseAction {
  id     String @id @default(cuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  type     ActionType
  status   ActionStatus @default(COMPLETED)
  label    String?
  notes    String?      @db.Text
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
}

enum CaseStatus {
  DRAFT
  ASSEMBLING
  ANALYZING
  STRATEGY_PENDING
  STRATEGY_SELECTED
  GENERATING
  READY
  SENT
  AWAITING_RESPONSE
  ESCALATING
  RESOLVED
  CLOSED
}

enum Strategy {
  QUICK_ESCALATION
  STANDARD_RECOVERY
  GRADUAL_APPROACH
}

enum ActionType {
  CASE_CREATED
  CASE_UPDATED
  DOCUMENTS_UPLOADED
  AI_ANALYSIS_COMPLETED
  STRATEGY_SELECTED
  DEMAND_LETTER_GENERATED
  FINAL_NOTICE_GENERATED
  FILING_PACKET_GENERATED
  COURT_FORM_GENERATED
  DEFAULT_JUDGMENT_GENERATED
  EMAIL_SENT
  CERTIFIED_MAIL_SENT
  REMINDER_SENT
  FINAL_NOTICE_SENT
  LAWYER_REVIEW_REQUESTED
  FILING_PREPARED
  SERVICE_INITIATED
  PAYMENT_RECEIVED
  CASE_CLOSED
  // Phase A
  DEMAND_LETTER_MAILED
  DEMAND_LETTER_DELIVERED
  EMAIL_OPENED
  EMAIL_CLICKED
  SETTLEMENT_SENT_FOR_SIGNATURE
  SETTLEMENT_SIGNED
  PAYMENT_PLAN_SENT_FOR_SIGNATURE
  PAYMENT_PLAN_SIGNED
  PORTAL_VIEWED
  PAYMENT_VIA_PORTAL
  DISPUTE_FILED
  PAYMENT_PLAN_PROPOSED
  FOLLOW_UP_SENT
  ATTORNEY_HANDOFF_INITIATED
}

enum ActionStatus {
  PENDING
  COMPLETED
  FAILED
  SKIPPED
}
