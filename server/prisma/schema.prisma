generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  cases        Case[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Case {
  id     String     @id @default(cuid())
  status CaseStatus @default(DRAFT)
  strategy Strategy?
  title  String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Claimant
  claimantName     String?
  claimantBusiness String?
  claimantAddress  String?
  claimantEmail    String?
  claimantPhone    String?

  // Debtor
  debtorName       String?
  debtorBusiness   String?
  debtorAddress    String?
  debtorEmail      String?
  debtorPhone      String?
  debtorEntityType String?

  // Claim details
  amountOwed         Decimal?  @db.Decimal(12, 2)
  amountPaid         Decimal?  @db.Decimal(12, 2)
  serviceDescription String?   @db.Text
  agreementDate      DateTime?
  serviceStartDate   DateTime?
  serviceEndDate     DateTime?
  invoiceDate        DateTime?
  paymentDueDate     DateTime?
  hasWrittenContract Boolean   @default(false)
  invoiceNumber      String?

  // AI-synthesized data
  extractedFacts  Json?
  caseTimeline    Json?
  evidenceSummary Json?
  missingInfo     Json?
  caseStrength    String?
  caseAssessment  Json?

  // Generated outputs
  caseSummary      String? @db.Text
  demandLetter     String? @db.Text
  demandLetterHtml String? @db.Text
  finalNotice      String? @db.Text
  finalNoticeHtml  String? @db.Text
  filingPacket         String? @db.Text
  filingPacketHtml     String? @db.Text
  courtFormType         String?
  courtFormInstructions Json?
  courtFormVerification Json?
  defaultJudgment       String? @db.Text
  defaultJudgmentHtml   String? @db.Text

  industry String?
  notes String? @db.Text

  documents Document[]
  actions   CaseAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Document {
  id       String @id @default(cuid())
  caseId   String
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String

  classification String?
  extractedText  String? @db.Text
  extractedFacts Json?
  supportsTags   String[]
  confidence     Float?
  summary        String? @db.Text

  uploadedAt DateTime @default(now())

  @@index([caseId])
}

model CaseAction {
  id     String @id @default(cuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  type     ActionType
  status   ActionStatus @default(COMPLETED)
  label    String?
  notes    String?      @db.Text
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
}

enum CaseStatus {
  DRAFT
  ASSEMBLING
  ANALYZING
  STRATEGY_PENDING
  STRATEGY_SELECTED
  GENERATING
  READY
  SENT
  AWAITING_RESPONSE
  ESCALATING
  RESOLVED
  CLOSED
}

enum Strategy {
  QUICK_ESCALATION
  STANDARD_RECOVERY
  GRADUAL_APPROACH
}

enum ActionType {
  CASE_CREATED
  CASE_UPDATED
  DOCUMENTS_UPLOADED
  AI_ANALYSIS_COMPLETED
  STRATEGY_SELECTED
  DEMAND_LETTER_GENERATED
  FINAL_NOTICE_GENERATED
  FILING_PACKET_GENERATED
  COURT_FORM_GENERATED
  DEFAULT_JUDGMENT_GENERATED
  EMAIL_SENT
  CERTIFIED_MAIL_SENT
  REMINDER_SENT
  FINAL_NOTICE_SENT
  LAWYER_REVIEW_REQUESTED
  FILING_PREPARED
  SERVICE_INITIATED
  PAYMENT_RECEIVED
  CASE_CLOSED
}

enum ActionStatus {
  PENDING
  COMPLETED
  FAILED
  SKIPPED
}
