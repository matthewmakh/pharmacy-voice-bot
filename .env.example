# Existing
DATABASE_URL=postgresql://user:password@localhost:5432/collections
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET=your-long-random-secret-here
PORT=3001
NODE_ENV=development
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25

# Phase A — vendor keys
LOB_API_KEY=live_or_test_...
RESEND_API_KEY=re_...
DROPBOX_SIGN_API_KEY=...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email sender (Resend) — verify SPF/DKIM/DMARC on this domain
EMAIL_SENDER_DOMAIN=mail.reclaimful.com
EMAIL_FROM_ADDRESS=hello@mail.reclaimful.com

# Auto follow-up scheduler (BullMQ)
REDIS_URL=redis://localhost:6379

# Public base URL — used in debtor portal links and Stripe success/cancel URLs
PUBLIC_BASE_URL=http://localhost:5173

# Phase B — vendor keys (added when Phase B starts)
PROOF_API_KEY=
INFOTRACK_API_KEY=
